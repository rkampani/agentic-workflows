{
  "name": "agentic-perf-testing-platform",
  "version": "1.0.0",
  "private": true,
  "description": "Agentic AI Performance Testing Platform for Spring Boot microservices",
  "workspaces": [
    "backend/mcp-servers/service-registry",
    "backend/mcp-servers/perf-test-server",
    "backend/mcp-servers/spring-metrics",
    "backend/mcp-servers/results-analyzer",
    "frontend/dashboard"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "build:registry": "npm run build -w backend/mcp-servers/service-registry",
    "build:perf": "npm run build -w backend/mcp-servers/perf-test-server",
    "build:metrics": "npm run build -w backend/mcp-servers/spring-metrics",
    "build:analyzer": "npm run build -w backend/mcp-servers/results-analyzer",
    "build:dashboard": "npm run build -w frontend/dashboard",
    "dashboard": "npm run start -w frontend/dashboard"
  }
}
