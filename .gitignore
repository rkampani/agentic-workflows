# ── Node / TypeScript build output ───────────────
node_modules/
dist/
*.js.map
*.d.ts
*.d.ts.map
*.tsbuildinfo

# ── Python ───────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.egg-info/
.venv/
venv/
.eggs/
pip-log.txt
.pytest_cache/

# ── Secrets ──────────────────────────────────────
.env
.env.*
!.env.example

# ── Runtime-generated (never commit) ─────────────
test-scripts/
results/
baselines/

# ── Test data (real IDs / credentials, local only) ──
test-data/

# ── Dev tooling only ─────────────────────────────
mock-service/

# ── OS / IDE ─────────────────────────────────────
.DS_Store
.idea/
.vscode/
*.swp
*.swo

# ── Misc ─────────────────────────────────────────
.claude/
package-lock.json
